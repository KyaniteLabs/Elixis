# SoulCraft Environment Configuration
# Copy to .env and fill in your values

# LLM Provider Settings
# Supported providers: "ollama" (default) or "openai" for OpenAI-compatible APIs
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_FALLBACK_URL=
LLM_MODEL=gemma-4b
LLM_CLASSIFY_MODEL=
LLM_API_KEY=

# Translation cache directory (defaults to .soulcraft/translations/ in project)
# SOULCRAFT_CACHE_DIR=

# Traefik / Domain Settings
TRAEFIK_DOMAIN=your-tailnet.ts.net

# Deployment Settings (for CI/CD)
VPS_HOST=your-vps-ip
VPS_USER=deploy
# VPS_SSH_KEY= (add to GitHub secrets, not here)

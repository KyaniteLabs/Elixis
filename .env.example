# Elixis Environment Configuration
# Copy to .env and fill in your values

# LLM Provider Settings
# Local VPS inference:
LLM_PROVIDER=openai
LLM_BASE_URL=http://llama-local:8085/v1
LLM_FALLBACK_URL=
LLM_MODEL=Qwen3.5-0.8B-Q4_K_M.gguf
LLM_CLASSIFY_MODEL=
LLM_API_KEY=dummy

# Cloud inference:
# GLM 5.1 through Z.ai's OpenAI-compatible API:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.z.ai/api/paas/v4
# LLM_MODEL=glm-5.1
# ZAI_API_KEY=
#
# Kimi/Moonshot through its OpenAI-compatible API:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.moonshot.ai/v1
# LLM_MODEL=kimi-k2.6
# KIMI_API_KEY=
#
# Anthropic Messages API:
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5

# Optional local fallback for OpenAI-compatible providers only. Leave empty for
# cloud deployments so failures stay explicit instead of falling through to local inference.
# LLM_FALLBACK_URL=http://llama-local:8085/v1

# Admin API key for diagnostics, run history, backups, and cache deletion.
# Generate a long random value before deployment.
ADMIN_API_KEY=change-me-long-random-token

# CORS
CORS_ORIGIN=https://elixis.kyanitelabs.tech

# Image used by CI/CD deploy. Local scripts can keep the default elixis:latest.
ELIXIS_IMAGE=ghcr.io/kyanitelabs/elixis:latest

# Deployment (CI/CD — secrets go in GitHub, not here)
VPS_HOST=your-vps-host.example.com
VPS_USER=root

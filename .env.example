# Elixis Environment Configuration
# Copy to .env and fill in your values

# LLM Provider Settings
# Primary/fallback: llama-local on the VPS Docker network
LLM_PROVIDER=openai
LLM_BASE_URL=http://llama-local:8085/v1
LLM_FALLBACK_URL=http://llama-local:8085/v1
LLM_MODEL=Qwen3.5-0.8B-Q4_K_M.gguf
LLM_CLASSIFY_MODEL=
LLM_API_KEY=dummy

# Admin API key for diagnostics, run history, backups, and cache deletion.
# Generate a long random value before deployment.
ADMIN_API_KEY=change-me-long-random-token

# CORS
CORS_ORIGIN=https://elixis.kyanitelabs.tech

# Image used by CI/CD deploy. Local scripts can keep the default elixis:latest.
ELIXIS_IMAGE=ghcr.io/kyanitelabs/elixis:latest

# Deployment (CI/CD — secrets go in GitHub, not here)
VPS_HOST=your-vps-host.example.com
VPS_USER=root

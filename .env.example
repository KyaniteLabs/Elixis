# SoulCraft Environment Configuration
# Copy to .env and fill in your values

# LLM Provider Settings
LLM_PROVIDER=openai
LLM_BASE_URL=http://172.17.0.1:8085/v1
LLM_FALLBACK_URL=http://100.66.225.85:1234/v1
LLM_MODEL=gemma-4b
LLM_API_KEY=

# Traefik / Domain Settings
TRAEFIK_DOMAIN=your-tailnet.ts.net

# Deployment Settings (for CI/CD)
VPS_HOST=your-vps-ip
VPS_USER=deploy
# VPS_SSH_KEY= (add to GitHub secrets, not here)
